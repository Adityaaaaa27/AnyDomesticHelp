# ─── AnyDomesticHelp PHP API – Apache Configuration ──────────────────────────
# Upload this file to: public_html/api/.htaccess

# ─── CORS Headers ────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "POST, GET, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>

# ─── Handle OPTIONS preflight requests ───────────────────────────────────────
RewriteEngine On
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# ─── Clean URLs ──────────────────────────────────────────────────────────────
# Allow /api/employer-registration to map to employer-registration.php
# This way the mobile app can call the same paths as the Node.js server
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([a-zA-Z0-9_-]+)$ $1.php [L,QSA]

# ─── Security ────────────────────────────────────────────────────────────────
# Prevent directory listing
Options -Indexes

# Block access to config.php directly via browser (still accessible via PHP require)
<Files "config.php">
    # Allow PHP to include it, but block direct HTTP access
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

# ─── Gzip Compression ───────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json
</IfModule>
